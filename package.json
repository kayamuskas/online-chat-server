{
  "name": "@chat/root",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "linux",
        "darwin",
        "current"
      ],
      "cpu": [
        "arm64",
        "x64",
        "current"
      ]
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:api": "pnpm --filter @chat/api build",
    "build:web": "pnpm --filter @chat/web build",
    "build:worker": "pnpm --filter @chat/worker build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "compose:smoke": "docker compose -f infra/compose/compose.yaml up --build --wait",
    "compose:down": "docker compose -f infra/compose/compose.yaml down -v",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6"
  }
}
